{
  "name": "@johnshopkins/rave-js",
  "version": "0.0.0",
  "description": "Johns Hopkins University Rave Alert JavaScript integration",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/main.cjs",
  "module": "./dist/main.es.js",
  "exports": {
    ".": {
      "import": "./dist/main.es.js",
      "require": "./dist/main.cjs"
    }
