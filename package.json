  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.config.iife.js",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnshopkins/rave-js.git"
  },
  "bugs": {
    "url": "https://github.com/johnshopkins/rave-js/issues"
  },
  "contributors": [
    {
      "name": "Eric Conrad",
      "email": "eric.conrad@jhu.edu"
    },
    {
      "name": "Jen Wachter",
      "email": "jwachter@jhu.edu"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@johnshopkins/jhu-wds": "github:johnshopkins/jhu-wds",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "sass-embedded": "^1.97.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "vite": "^7.2.4",
    "vite-plugin-eslint2": "^5.0.4",
    "vite-plugin-stylelint": "^6.0.2",
    "vitest": "^4.0.17"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
